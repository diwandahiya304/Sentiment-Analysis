# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ──────────────────────────────────────────────
venv/
env/
.venv/
.env/

# ── Jupyter ───────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Data  (large files — upload separately or use Git LFS) ───────────
data/*.csv
data/*.xlsx
data/*.json
data/*.parquet
data/*.zip
!data/.gitkeep

# ── Trained Models ────────────────────────────────────────────────────
models/*.pkl
models/*.h5
models/*.keras
models/*.pt
models/*.bin
models/*.joblib
!models/.gitkeep

# ── Outputs ───────────────────────────────────────────────────────────
outputs/*.png
outputs/*.pdf
outputs/*.html
notebooks/outputs/
notebooks/models/
!outputs/.gitkeep

# ── IDE ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── OS ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Env variables ─────────────────────────────────────────────────────
.env
*.env

# ── Dev / temp artefacts ──────────────────────────────────────────────
patch_notebook.py
fix_rf_notebook.py
tmp_check.txt
"{src,notebooks,data,models,outputs}"/
