# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ──────────────────────────────────────────────
venv/
env/
.venv/
.env/

# ── Jupyter ───────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Data  (large files — download separately, not tracked by Git) ─────
data/*.csv
data/*.xlsx
data/*.json
data/*.parquet
data/*.zip
!data/.gitkeep

# ── Trained Models ────────────────────────────────────────────────────
models/*.pkl
models/*.h5
models/*.keras
models/*.pt
models/*.bin
models/*.joblib
!models/.gitkeep

# ── Outputs (generated artefacts) ────────────────────────────────────
outputs/*.png
outputs/*.pdf
outputs/*.html
outputs/*.csv
notebooks/outputs/
notebooks/models/
!outputs/.gitkeep

# ── IDE ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── OS ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Env variables ─────────────────────────────────────────────────────
.env
*.env
